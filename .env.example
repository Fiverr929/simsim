# Database
DATABASE_URL="file:./dev.db"

# Google Gemini — required for AI automation
# Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Etsy API — optional, only needed for live publishing
# Register your app at https://www.etsy.com/developers/register
ETSY_API_KEY=your_etsy_api_key
ETSY_SHARED_SECRET=your_etsy_shared_secret
ETSY_REFRESH_TOKEN=your_etsy_refresh_token
ETSY_SHOP_ID=your_etsy_shop_id
